# === Database ===
# Option A: Local Postgres (docker-compose up -d)
DATABASE_URL=postgresql://land_scout:land_scout@localhost:5432/land_scout

# Option B: Neon (prod/staging) — get from neon.tech dashboard
# DATABASE_URL=postgresql://user:pass@ep-xxx.neon.tech/neondb?sslmode=require

# === Neon Auth (only needed for auth features) ===
# NEON_AUTH_BASE_URL=https://ep-xxx.neon.tech/neondb/auth
# NEON_AUTH_COOKIE_SECRET=<openssl rand -base64 32>

# === Scrape Webhook (optional) ===
SCRAPE_WEBHOOK_URL=https://example.com/land-scout/run
SCRAPE_WEBHOOK_BEARER_TOKEN=
SCRAPE_WEBHOOK_SECRET=
